{
  "manifest_version": 3,
  "name": "Marketplace Du'a",
  "version": "1.2.0",
  "description": "A gentle reminder to recite the du'a before entering a marketplace — on Amazon, eBay, Facebook Marketplace, and any sites you add.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Marketplace Du'a settings",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["defaults.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
