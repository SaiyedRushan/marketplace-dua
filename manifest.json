{
  "manifest_version": 3,
  "name": "Marketplace Du'a",
  "version": "1.3.0",
  "description": "A gentle reminder to recite the du'a before entering a marketplace — on Amazon, eBay, Facebook Marketplace, and any sites you add.",
  "permissions": ["storage", "scripting"],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Marketplace Du'a settings",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*", "*://*.amazon.ca/*", "*://*.amazon.co.uk/*", "*://*.amazon.de/*",
        "*://*.amazon.fr/*", "*://*.amazon.it/*", "*://*.amazon.es/*", "*://*.amazon.nl/*",
        "*://*.amazon.se/*", "*://*.amazon.pl/*", "*://*.amazon.com.tr/*", "*://*.amazon.co.jp/*",
        "*://*.amazon.in/*", "*://*.amazon.com.au/*", "*://*.amazon.com.br/*", "*://*.amazon.com.mx/*",
        "*://*.amazon.sg/*", "*://*.amazon.sa/*", "*://*.amazon.ae/*", "*://*.amazon.eg/*",
        "*://*.ebay.com/*", "*://*.ebay.co.uk/*", "*://*.ebay.de/*", "*://*.ebay.com.au/*",
        "*://*.ebay.ca/*", "*://*.ebay.fr/*", "*://*.ebay.it/*", "*://*.ebay.es/*",
        "*://*.ebay.nl/*", "*://*.ebay.at/*", "*://*.ebay.ch/*", "*://*.ebay.ie/*",
        "*://*.ebay.com.sg/*", "*://*.ebay.com.my/*", "*://*.ebay.ph/*", "*://*.ebay.in/*",
        "*://*.facebook.com/*",
        "*://*.etsy.com/*",
        "*://*.walmart.com/*", "*://*.walmart.ca/*",
        "*://*.aliexpress.com/*", "*://*.aliexpress.us/*",
        "*://*.alibaba.com/*",
        "*://*.temu.com/*",
        "*://*.shein.com/*",
        "*://*.target.com/*",
        "*://*.bestbuy.com/*", "*://*.bestbuy.ca/*",
        "*://*.mercari.com/*",
        "*://*.craigslist.org/*",
        "*://*.wayfair.com/*", "*://*.wayfair.ca/*", "*://*.wayfair.co.uk/*",
        "*://*.wish.com/*",
        "*://*.noon.com/*"
      ],
      "js": ["defaults.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
